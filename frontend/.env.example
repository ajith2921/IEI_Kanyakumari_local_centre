# ──────────────────────────────────────────────
# Frontend Environment Variables — copy to frontend/.env
# ──────────────────────────────────────────────

# Development (local)
VITE_API_URL=http://localhost:8000/api
VITE_UPLOADS_BASE_URL=http://localhost:8000

# Production — set in Vercel dashboard (Project Settings → Environment Variables)
# Replace with your actual Render backend URL:
# VITE_API_URL=https://iei-kanyakumari-backend.onrender.com/api
# VITE_UPLOADS_BASE_URL=https://iei-kanyakumari-backend.onrender.com
