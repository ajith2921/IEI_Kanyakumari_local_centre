# ──────────────────────────────────────────────
# Backend Environment Variables — copy to backend/.env
# ──────────────────────────────────────────────

# Application secret for JWT signing (use a long random string)
SECRET_KEY=replace-with-a-strong-random-secret-min-32-chars

# Admin login credentials (seeded at startup)
ADMIN_USERNAME=replace-admin-username
ADMIN_PASSWORD=replace-admin-password

# JWT token expiry (in minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Comma-separated list of allowed frontend origins (include production domain)
# Example: https://your-site.vercel.app,https://www.yourdomain.com
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Supabase Configuration
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_SUPABASE_PROJECT_ID.supabase.co
SUPABASE_KEY=REPLACE_WITH_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY
