DATABASE_URL=sqlite:///./app.db
SECRET_KEY=replace-with-a-strong-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=120
ADMIN_USERNAME=replace-admin-username
ADMIN_PASSWORD=replace-admin-password
FRONTEND_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
AUTO_SEED_MEMBERSHIP_PLANS=true

# Premium billing integration (checkout + webhook)
MEMBERSHIP_PAYMENT_PROVIDER=sandbox
MEMBERSHIP_PAYMENT_CHECKOUT_BASE_URL=https://payments.example.test/checkout
MEMBERSHIP_PAYMENT_WEBHOOK_SECRET=replace-with-webhook-signing-secret
MEMBERSHIP_PAYMENT_WEBHOOK_SIGNATURE_HEADER=x-membership-signature
MEMBERSHIP_PAYMENT_ALLOW_UNSIGNED_WEBHOOKS=false
MEMBERSHIP_PAYMENT_STRIPE_WEBHOOK_SECRET=
MEMBERSHIP_PAYMENT_STRIPE_SIGNATURE_HEADER=stripe-signature
MEMBERSHIP_PAYMENT_RAZORPAY_WEBHOOK_SECRET=
MEMBERSHIP_PAYMENT_RAZORPAY_SIGNATURE_HEADER=x-razorpay-signature
MEMBERSHIP_PAYMENT_STRIPE_PUBLISHABLE_KEY=
MEMBERSHIP_PAYMENT_RAZORPAY_KEY_ID=

# Membership security controls
MEMBERSHIP_ACCESS_TOKEN_EXPIRE_MINUTES=120
MEMBERSHIP_LOCKOUT_MAX_ATTEMPTS=5
MEMBERSHIP_LOCKOUT_MINUTES=15
MEMBERSHIP_REFRESH_TOKEN_EXPIRY_DAYS=14
MEMBERSHIP_RESET_TOKEN_EXPIRY_MINUTES=30

# Keep reset token hidden in normal environments.
# Set true only for local development/testing.
MEMBERSHIP_EXPOSE_RESET_TOKEN=false

# Membership endpoint throttling
MEMBERSHIP_LOGIN_THROTTLE_LIMIT=20
MEMBERSHIP_LOGIN_THROTTLE_WINDOW_SECONDS=300
MEMBERSHIP_FORGOT_THROTTLE_LIMIT=5
MEMBERSHIP_FORGOT_THROTTLE_WINDOW_SECONDS=900
MEMBERSHIP_RESET_THROTTLE_LIMIT=10
MEMBERSHIP_RESET_THROTTLE_WINDOW_SECONDS=900
MEMBERSHIP_REFRESH_THROTTLE_LIMIT=30
MEMBERSHIP_REFRESH_THROTTLE_WINDOW_SECONDS=300
MEMBERSHIP_THROTTLE_CLEANUP_SECONDS=300
